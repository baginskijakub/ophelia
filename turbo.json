{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "env": ["QSTASH_TOKEN", "PLATFORM_URL", "UPLOADTHING_APP_ID"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "styles.css",
        "assets/**"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "env": ["QSTASH_TOKEN", "PLATFORM_URL", "UPLOADTHING_APP_ID"],
      "cache": false,
      "persistent": true
    },
    "clean": {}
  }
}
