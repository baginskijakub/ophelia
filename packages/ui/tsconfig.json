{
  "extends": "@ophelia/typescript-config/react-library.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist", 
    "plugins": [{ "name": "typescript-plugin-css-modules" }],
    "declaration": true,
    "declarationMap": true
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"],
}
